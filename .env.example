# LLM provider: "ollama" | "azure_openai" | "anthropic"
LLM_PROVIDER=ollama

# --- Ollama (dev) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b

# --- Azure OpenAI (prod) ---
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>

# --- Anthropic (prod) ---
ANTHROPIC_API_KEY=<your-api-key>
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- SQL Server ---
# Format: mssql+pyodbc://user:password@host/database?driver=ODBC+Driver+18+for+SQL+Server
DB_CONNECTION_STRING=mssql+pyodbc://user:password@localhost/cfo_db?driver=ODBC+Driver+18+for+SQL+Server

LOG_LEVEL=INFO
